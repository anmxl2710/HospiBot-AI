<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="hybrid_robot">
    <static>false</static>
    <pose>0 0 0.3 0 0 0</pose>

    <!-- BASE -->
    <link name="base_link">
      <inertial>
        <mass>7.0</mass>
        <inertia>
          <ixx>0.14</ixx>
          <iyy>0.14</iyy>
          <izz>0.14</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <geometry>
          <cylinder>
            <radius>0.33</radius>
            <length>0.22</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="base_visual">
        <geometry>
          <cylinder>
            <radius>0.33</radius>
            <length>0.22</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.75 0.15 1</ambient>
        </material>
      </visual>
    </link>

    <!-- LEFT WHEEL -->
    <link name="left_wheel">
      <pose>0 0.34 0 0 1.57 0</pose>
      <inertial>
        <mass>1.2</mass>
        <inertia>
          <ixx>0.012</ixx>
          <iyy>0.012</iyy>
          <izz>0.012</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="left_collision">
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="left_visual">
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
        </material>
      </visual>
    </link>

    <!-- RIGHT WHEEL -->
    <link name="right_wheel">
      <pose>0 -0.34 0 0 1.57 0</pose>
      <inertial>
        <mass>1.2</mass>
        <inertia>
          <ixx>0.012</ixx>
          <iyy>0.012</iyy>
          <izz>0.012</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="right_collision">
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="right_visual">
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
        </material>
      </visual>
    </link>

    <!-- JOINTS -->
    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1000</lower>
          <upper>1000</upper>
        </limit>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1000</lower>
          <upper>1000</upper>
        </limit>
      </axis>
    </joint>

    <!-- DIFF DRIVE PLUGIN -->
    <plugin name="hybrid_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/hybrid</namespace>
      </ros>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.68</wheel_separation>
      <wheel_diameter>0.2</wheel_diameter>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
    </plugin>

  </model>
</sdf>
